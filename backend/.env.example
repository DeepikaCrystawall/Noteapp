NODE_ENV=development
PORT=3001

# Database
# Use port 5433 when running Postgres via docker-compose (5432 is often taken by a local PostgreSQL install)
DATABASE_URL=postgresql://noteapp:noteapp_secret@localhost:5433/noteapp_db
DB_HOST=localhost
DB_PORT=5433
DB_NAME=noteapp_db
DB_USER=noteapp
DB_PASSWORD=noteapp_secret
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cache TTL (seconds)
CACHE_TTL=300

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URL
FRONTEND_URL=http://localhost:5173
