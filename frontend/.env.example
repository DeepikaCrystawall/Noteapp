# Copy to .env:  cp .env.example .env
# Restart the Vite dev server after changes.

# Backend API (must include /api)
VITE_API_URL=http://localhost:3001/api

# Socket.IO server (host + port only)
VITE_SOCKET_URL=http://localhost:3001

# Static files served by the backend (/uploads, avatars)
VITE_ASSETS_URL=http://localhost:3001

# LAN example (match CORS_ORIGIN in backend/.env):
# VITE_API_URL=http://192.168.x.x:3001/api
# VITE_SOCKET_URL=http://192.168.x.x:3001
# VITE_ASSETS_URL=http://192.168.x.x:3001

VITE_APP_NAME=CollabNotes
